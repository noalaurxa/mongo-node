<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Social Media - Posts</title>

  <!-- Materialize CSS -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">

  <!-- Iconos -->
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

  <style>
    .card-image img {
      height: 200px;
      width: 100%;
      object-fit: cover;
    }
  </style>
</head>

<body class="grey lighten-4">

  <!-- Navbar -->
  <nav>
    <div class="nav-wrapper teal">
      <a href="/" class="brand-logo center">Social Media</a>
    </div>
  </nav>

  <div class="container">

    <!-- Header -->
    <div class="section center-align">
      <h4 class="blue-text text-darken-2">Bienvenido a Social Media</h4>

      <a href="/posts/create" class="btn waves-effect waves-light teal">
        <i class="material-icons left">add</i> Nuevo Post
      </a>
    </div>

    <div class="row">

      <% if (posts.length === 0) { %>
        <div class="col s12 center-align">
          <h5 class="grey-text">No hay posts aún 🚫</h5>
        </div>
      <% } %>

      <% posts.forEach(post => { %>

        <div class="col s12 m6 l4">
          <div class="card hoverable">

            <!-- Imagen dinámica -->
            <div class="card-image">
                <img 
                    src="<%= post.imageUrl %>" 
                    alt="Imagen del post"
                    onerror="this.onerror=null; this.src='https://media.istockphoto.com/id/627795510/photo/example.jpg?s=612x612&w=0&k=20&c=lpUf5rjPVd6Kl_M6heqC8sUncR4FLmtsRzeYdTr5X_I='"
                >
            </div>

            <!-- Contenido -->
            <div class="card-content">

              <span class="card-title truncate">
                <%= post.title %>
              </span>

              <p class="grey-text text-darken-1" style="margin-bottom:10px;">
                <%= post.content.length > 100 
                  ? post.content.substring(0,100) + "..." 
                  : post.content %>
              </p>

              <!-- Hashtags -->
              <% if (post.hashtags && post.hashtags.length > 0) { %>
                <div>
                  <% post.hashtags.forEach(tag => { %>
                    <span class="chip teal lighten-4">#<%= tag %></span>
                  <% }) %>
                </div>
              <% } %>

            </div>

            <!-- Footer -->
            <div class="card-action">

              <span class="grey-text">
                <i class="material-icons tiny">person</i>
                <%= post.user?.name || "Sin usuario" %>
              </span>

              <div class="right">

                <a href="/posts/edit/<%= post._id %>" class="btn-floating btn-small teal">
                  <i class="material-icons">edit</i>
                </a>

                <a href="/posts/delete/<%= post._id %>" 
                   class="btn-floating btn-small red"
                   onclick="return confirm('¿Eliminar este post?')">
                  <i class="material-icons">delete</i>
                </a>

              </div>

            </div>

          </div>
        </div>

      <% }) %>

    </div>
  </div>

  <!-- Materialize JS -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>

</body>
</html>