<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Crear Post</title>

  <!-- Materialize CSS -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">

  <!-- Iconos -->
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>

<body class="grey lighten-4">

  <!-- Navbar -->
  <nav>
    <div class="nav-wrapper teal">
      <a href="/" class="brand-logo center">Social Media</a>
    </div>
  </nav>

  <div class="container">

    <h4 class="center-align">Crear Nuevo Post</h4>

    <div class="row">
      <form action="/posts" method="POST" class="col s12">

        <div class="card">
          <div class="card-content">

            <!-- Título -->
            <div class="input-field">
              <i class="material-icons prefix">title</i>
              <input id="title" type="text" name="title" required minlength="5" maxlength="30">
              <label for="title">Título del Post</label>
            </div>

            <!-- Contenido -->
            <div class="input-field">
              <i class="material-icons prefix">description</i>
              <textarea id="content" class="materialize-textarea" name="content" required minlength="10"></textarea>
              <label for="content">Contenido</label>
            </div>

            <!-- Hashtags -->
            <div class="input-field">
              <i class="material-icons prefix">tag</i>
              <input id="hashtags" type="text" name="hashtags" placeholder="#tag1,#tag2">
              <label for="hashtags">Hashtags</label>
            </div>

            <!-- Imagen -->
            <div class="input-field">
              <i class="material-icons prefix">image</i>
              <input id="imageUrl" type="text" name="imageUrl">
              <label for="imageUrl">URL de la Imagen</label>
            </div>

            <!-- SELECT USUARIO (CORRECTO) -->
            <div class="input-field">
              <i class="material-icons prefix">person</i>

              <select name="userId" required>
                <option value="" disabled selected>Selecciona un usuario</option>

                <% users.forEach(user => { %>
                  <option value="<%= user._id %>">
                    <%= user.name %> <%= user.lastName %>
                  </option>
                <% }) %>

              </select>

              <label>Usuario</label>
            </div>

          </div>

          <!-- Botones -->
          <div class="card-action center-align">
            <button type="submit" class="btn waves-effect waves-light teal">
              <i class="material-icons left">send</i> Crear Post
            </button>

            <a href="/posts" class="btn grey">
              Cancelar
            </a>
          </div>

        </div>

      </form>
    </div>

  </div>

  <!-- Materialize JS -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>

  <!-- ACTIVAR SELECT -->
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var elems = document.querySelectorAll('select');
      M.FormSelect.init(elems);
    });
  </script>

</body>
</html>